# Safe local environment template for AGEZT.
#
# Keep real API keys out of repo files. Prefer the encrypted vault:
#   agt provider creds set OPENAI_API_KEY
#   agt provider creds set MINIMAX_API_KEY
#   agt provider creds set DEEPSEEK_API_KEY
#
# If you use AGEZT_VAULT_PASSPHRASE, source it from an OS secret manager or
# shell session. Do not store the live passphrase in `.env`.

# Stricter security posture: prevents agents from using the overseer tool to
# edit/create agents. Operator console/CLI edits still work.
AGEZT_OVERSEER_FLEET_LOCK=off

# Set when the web console is fronted by a real hostname/reverse proxy/tunnel.
# Comma-separated hostnames, without scheme.
AGEZT_WEB_ALLOWED_HOSTS=

# Vault passphrase placeholders. Leave blank in files; populate via OS secret
# manager or shell when needed.
AGEZT_VAULT_PASSPHRASE=
AGEZT_VAULT_PASSPHRASE_NEW=

# Provider key placeholders. Prefer `agt provider creds set ...`; keep these
# blank if you copy this template to `.env`.
# MINIMAX_API_KEY=
# DEEPSEEK_API_KEY=

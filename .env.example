# Safe local environment template for AGEZT.
#
# Keep real API keys out of repo files. Prefer the encrypted vault:
#   agt provider creds set OPENAI_API_KEY
#   agt provider creds set MINIMAX_API_KEY
#   agt provider creds set DEEPSEEK_API_KEY
#
# If you use AGEZT_VAULT_PASSPHRASE, source it from an OS secret manager or
# shell session. Do not store the live passphrase in `.env`.

# Stricter security posture: prevents agents from using the overseer tool to
# edit/create agents. Operator console/CLI edits still work.
AGEZT_OVERSEER_FLEET_LOCK=off

# Set when the web console is fronted by a real hostname/reverse proxy/tunnel.
# Comma-separated hostnames, without scheme.
AGEZT_WEB_ALLOWED_HOSTS=
# For any public tunnel, set a strong password. Strict mode requires both the
# boot token and a password session for data routes.
# AGEZT_WEB_PASSWORD=
# AGEZT_WEB_PASSWORD_STRICT=on

# Optional supervised tunnel for the Web UI. Blank = disabled.
# cloudflare/cloudflared prints an automatic https://*.trycloudflare.com URL.
# ngrok requires ngrok auth/config. tailscale is tailnet-only; tailscale-funnel
# is public and requires Funnel enabled in Tailscale.
AGEZT_TUNNEL=
AGEZT_TUNNEL_TARGET=

# Optional first-party Playwright browser actions. Requires Node + Playwright.
# Leave disabled unless you need governed JS-rendered page interaction.
AGEZT_BROWSER_ACTIONS=
AGEZT_BROWSER_ACTION_DRIVER=
AGEZT_BROWSER_ACTION_NODE=
AGEZT_BROWSER_ACTION_ALLOWED_HOSTS=
AGEZT_BROWSER_ACTION_ALLOW_ALL=
AGEZT_BROWSER_ACTION_ALLOW_LOOPBACK=
AGEZT_BROWSER_ACTION_ALLOW_PRIVATE=
AGEZT_BROWSER_ACTION_ALLOW_USER_PROFILE=
AGEZT_BROWSER_ACTION_USER_DATA_DIR=
AGEZT_BROWSER_ACTION_ALLOW_REMOTE_CDP=
AGEZT_BROWSER_ACTION_REMOTE_CDP_URL=
AGEZT_BROWSER_ACTION_SESSION_DIR=

# Optional execution profiles for governed shell/code/peer execution.
# Allow/deny are comma/space separated profile ids:
# local, warden, docker, ssh, remote-agezt.
# Deny wins over allow. Blank = no extra execution-profile policy.
AGEZT_EXEC_PROFILE_ALLOW=
AGEZT_EXEC_PROFILE_DENY=
# Optional profile-specific env passthrough. AGEZT_* is never forwarded.
# Non-secret names go in AGEZT_EXEC_ENV_*; secret-shaped names go in
# AGEZT_EXEC_SECRET_ENV_*; vault-backed temporary file mounts go in
# AGEZT_EXEC_SECRET_FILES_* as KEY or KEY:filename.
AGEZT_EXEC_ENV_LOCAL=
AGEZT_EXEC_ENV_WARDEN=
AGEZT_EXEC_ENV_DOCKER=
AGEZT_EXEC_SECRET_ENV_LOCAL=
AGEZT_EXEC_SECRET_ENV_WARDEN=
AGEZT_EXEC_SECRET_ENV_DOCKER=
AGEZT_EXEC_SECRET_FILES_LOCAL=
AGEZT_EXEC_SECRET_FILES_WARDEN=
AGEZT_EXEC_SECRET_FILES_DOCKER=
# Optional remote/cloud secret handoff policy. Blank/deny = do not export local
# secret values or metadata to remote-agezt/cloud profiles. metadata = future
# adapters may receive secret names/labels only; values are still never exported.
AGEZT_EXEC_REMOTE_SECRET_POLICY=

# Optional Docker/Podman warden backend. Enables `agt run --exec-profile docker`
# when the runtime is available.
AGEZT_WARDEN_DOCKER=
AGEZT_WARDEN_DOCKER_RUNTIME=
AGEZT_WARDEN_DOCKER_IMAGE=
AGEZT_WARDEN_DOCKER_NETWORK=

# Optional SSH execution backend. Enables `agt run --exec-profile ssh` for
# shell/code_exec; code_exec syncs its generated workspace to the remote host.
AGEZT_EXEC_SSH=
AGEZT_EXEC_SSH_TARGET=
AGEZT_EXEC_SSH_WORKDIR=
AGEZT_EXEC_SSH_IDENTITY=
AGEZT_EXEC_SSH_PORT=
AGEZT_EXEC_SSH_STRICT_HOST_KEY=

# Optional Kubernetes execution backend. Enables `agt run --exec-profile k8s`
# for shell/code_exec through `kubectl exec`/`kubectl cp` into an existing pod.
AGEZT_EXEC_K8S=
AGEZT_EXEC_K8S_CONTEXT=
AGEZT_EXEC_K8S_NAMESPACE=
AGEZT_EXEC_K8S_POD=
AGEZT_EXEC_K8S_CONTAINER=
AGEZT_EXEC_K8S_WORKDIR=

# Optional Modal execution backend. Enables `agt run --exec-profile modal`
# for shell/code_exec through `modal shell --cmd` and `--add-local`.
AGEZT_EXEC_MODAL=
AGEZT_EXEC_MODAL_REF=
AGEZT_EXEC_MODAL_IMAGE=
AGEZT_EXEC_MODAL_ENVIRONMENT=
AGEZT_EXEC_MODAL_ADD_PYTHON=
AGEZT_EXEC_MODAL_WORKDIR=

# Optional Daytona execution backend. Enables `agt run --exec-profile daytona`
# for shell/code_exec commands through `daytona exec` in an existing sandbox.
AGEZT_EXEC_DAYTONA=
AGEZT_EXEC_DAYTONA_SANDBOX=
AGEZT_EXEC_DAYTONA_WORKDIR=

# Optional AGEZT peer mesh. Enables `remote_run`, which makes
# `agt run --exec-profile remote-agezt` selectable. Tokens can be embedded in
# this line, so prefer setting these through Config Center / the vault.
# Format: name=https://peer.example|token,name2=https://peer2.example
AGEZT_PEERS=
AGEZT_TENANT_PEERS=
# Optional peer event mirroring for remote-agezt runs. Set to metadata to
# journal token-free event metadata plus peer artifact metadata only. Set to
# redacted to also journal payload_redacted fields after local pattern
# redaction. Peer tokens and artifact bytes are never mirrored.
AGEZT_REMOTE_EVENT_MIRROR=
# Optional REST artifact byte transfer from this daemon to authenticated peers.
# Blank/off = deny. allow = GET /api/v1/artifacts/{id}/bytes returns base64
# bytes up to the daemon limit. Remote event mirroring never fetches bytes.
AGEZT_REMOTE_ARTIFACT_BYTES=

# Optional Workboard stale-claim sweeper. Blank = on-demand only via
# `agt workboard sweep`; set e.g. 5m to automatically reclaim claims whose
# heartbeat is older than AGEZT_WORKBOARD_STALE_AFTER.
AGEZT_WORKBOARD_SWEEP_EVERY=
AGEZT_WORKBOARD_STALE_AFTER=10m

# Vault passphrase placeholders. Leave blank in files; populate via OS secret
# manager or shell when needed.
AGEZT_VAULT_PASSPHRASE=
AGEZT_VAULT_PASSPHRASE_NEW=

# Provider key placeholders. Prefer `agt provider creds set ...`; keep these
# blank if you copy this template to `.env`.
# MINIMAX_API_KEY=
# DEEPSEEK_API_KEY=

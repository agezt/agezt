# The Web UI is built on Windows but rebuilt on Linux in CI (frontend-dist-in-sync
# diffs the committed bundle byte-for-byte). Force LF everywhere in the frontend
# and the committed bundle so a Windows checkout never rewrites EOLs — otherwise
# the committed dist (CRLF) differs from a Linux rebuild (LF) and the gate fails.
frontend/** text=auto eol=lf
kernel/webui/dist/** text eol=lf
*.sh text eol=lf
scripts/*.sh text eol=lf
# Binary build assets in the committed bundle (M951 self-hosted fonts): exempt
# from the text/eol normalization above so git never rewrites their bytes —
# otherwise the woff2 is corrupted and the Linux rebuild diff would never match.
kernel/webui/dist/**/*.woff2 binary
kernel/webui/dist/**/*.woff binary
kernel/webui/dist/**/*.ttf binary
# Built-in skill bundles are go:embed-ded into the binary (M852). Force LF so a
# Windows checkout doesn't embed CRLF — the shell setup script must run on Linux.
plugins/builtinskills/** text eol=lf

# build artifacts
/bin/
*.exe
*.test
*.out

# generated SDK types (regenerated by `make gen`)
/contract/gen/*.gen.go

# frontend deps (the BUILT bundle in kernel/webui/dist IS committed for go:embed;
# only node_modules is ignored)
/frontend/node_modules/
# frontend TS incremental build cache
*.tsbuildinfo
# Playwright e2e artifacts (the spec in frontend/e2e/ IS committed; only run
# output + downloaded browsers are ignored)
/frontend/test-results/
/frontend/playwright-report/
/frontend/blob-report/
/frontend/.playwright/
# ad-hoc frontend test output log captured from local Vitest runs
/frontend/ftest.txt

# python build/test artifacts
__pycache__/
*.pyc
*.egg-info/
/sdk/python/build/
/sdk/python/dist/

# typescript SDK deps + build output (the npm package is built in CI / on publish;
# package-lock.json IS committed so `npm ci` is reproducible)
/sdk/typescript/node_modules/
/sdk/typescript/dist/

# rust SDK build output (Cargo.lock IS committed so cargo builds are reproducible)
/sdk/rust/target/

# agent working notes + local agent config — never committed
next.md
.claude/

# editor / OS
.idea/
.vscode/
.DS_Store
Thumbs.db

# Agezt runtime (per SPEC-16; never inside repo, but defensive)
.agezt/

# Isolated test runtime home (AGEZT_HOME for go tests) — holds scratch state +
# a live control token; never commit. Mirrors the production .agezt/ above.
.agezt_test/

.dfmt/

# secrets / local env — never commit (API keys, tokens)
.env
.env.*
!.env.example
*.env
creds.json
# gateway HMAC signing secret (per-install, lives under the base dir; defensive)
agentgw.secret
# ad-hoc token/secret scratch files + local debug scripts (the gateway-auth
# investigation left these untracked; keep them from ever being committed)
*.token
token.txt
temp_token.txt
/decode_jwt.py
/verify_sig.py
/test_token.py
/test_hash.py
/test_hash.go
/debug_parse.py
/check_len.py
/test_gateway.py
/fix_scout.py
/scout_*.ps1
/update_scout*
/find_model.py
/find_302ai.py
/readlines.js
/start-daemon.ps1
/start-daemon.bat

# binary backups (agezt.exe.bak, agt.exe.bak-*, …)
*.bak
*.bak-*

# Local demo artifacts (Playwright screenshots, browser MCP)
.playwright-mcp/
webui-*.png

# editor/build backup files
*~
*.exe~

# dev.ps1 artifacts (isolated dev daemon home + local builds)
.dev-home/
bin/
.wrongstack/

# local ad-hoc test-counting script (machine-specific path, not portable)
/scout_tests.ps1

# npm is the source of truth for frontend (VULN-010); keep a stray pnpm lock out.
frontend/pnpm-lock.yaml
pnpm-lock.yaml

# Local git worktrees must never be committed (an orphan gitlink breaks actions/checkout).
.worktrees/

# build artifacts
/bin/
*.exe
*.test
*.out

# generated SDK types (regenerated by `make gen`)
/contract/gen/*.gen.go

# frontend deps (the BUILT bundle in kernel/webui/dist IS committed for go:embed;
# only node_modules is ignored)
/frontend/node_modules/
# frontend TS incremental build cache
*.tsbuildinfo

# agent working notes + local agent config — never committed
next.md
.claude/

# editor / OS
.idea/
.vscode/
.DS_Store
Thumbs.db

# Agezt runtime (per SPEC-16; never inside repo, but defensive)
.agezt/

.dfmt/

# secrets / local env — never commit (API keys, tokens)
.env
.env.*
*.env
creds.json

# Local demo artifacts (Playwright screenshots, browser MCP)
.playwright-mcp/
webui-*.png

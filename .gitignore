# build artifacts
/bin/
*.exe
*.test
*.out

# generated SDK types (regenerated by `make gen`)
/contract/gen/*.gen.go

# frontend deps (the BUILT bundle in kernel/webui/dist IS committed for go:embed;
# only node_modules is ignored)
/frontend/node_modules/
# frontend TS incremental build cache
*.tsbuildinfo
# Playwright e2e artifacts (the spec in frontend/e2e/ IS committed; only run
# output + downloaded browsers are ignored)
/frontend/test-results/
/frontend/playwright-report/
/frontend/blob-report/
/frontend/.playwright/

# python build/test artifacts
__pycache__/
*.pyc
*.egg-info/
/sdk/python/build/
/sdk/python/dist/

# typescript SDK deps + build output (the npm package is built in CI / on publish;
# package-lock.json IS committed so `npm ci` is reproducible)
/sdk/typescript/node_modules/
/sdk/typescript/dist/

# rust SDK build output (Cargo.lock IS committed so cargo builds are reproducible)
/sdk/rust/target/

# agent working notes + local agent config — never committed
next.md
.claude/

# editor / OS
.idea/
.vscode/
.DS_Store
Thumbs.db

# Agezt runtime (per SPEC-16; never inside repo, but defensive)
.agezt/

.dfmt/

# secrets / local env — never commit (API keys, tokens)
.env
.env.*
*.env
creds.json

# Local demo artifacts (Playwright screenshots, browser MCP)
.playwright-mcp/
webui-*.png
